# makeawish — Environment Variables
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local to git.

# ─── Firebase Client Configuration (Browser SDK) ───────────────
# Get these from: Firebase Console -> Project Settings -> General -> Your apps -> Web app
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id-here

# ─── Firebase Server Admin Configuration (Node.js SDK) ────────
# Generate a new private key from:
# Firebase Console -> Project Settings -> Service accounts -> Generate new private key
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# Put the complete private key in quotes (it spans multiple lines and has \n in it)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# ─── App Configuration ─────────────────────────────────────────
# Your app's public URL (used for auth redirects and cookie scopes)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# In production, set this to your Vercel deployment URL:
# NEXT_PUBLIC_SITE_URL=https://makeawish.app
